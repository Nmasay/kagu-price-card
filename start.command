#!/bin/bash
cd "$(dirname "$0")"
echo "==========================================="
echo "  プライスカード作成ツール ローカルサーバー"
echo "==========================================="
echo "サーバーを起動し、自動的にブラウザを開きます..."
echo "※このターミナルウィンドウを閉じるとサーバーが停止します。"
echo "==========================================="

# ブラウザで自動的に開く
open "http://localhost:8000"

# Pythonで簡易サーバーを起動 (ポート: 8000)
python3 -m http.server 8000
